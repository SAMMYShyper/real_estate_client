<style>
	:root {
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		--ink: #162317;
		--muted: #5d6570;
		--cream: #fff8ef;
		--orange: #fd8b17;
		--blue: #1164b0;
		--blue-dark: #083d72;
		--blue-soft: #e9f3ff;
		--white: #ffffff;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		background: var(--cream);
		color: var(--ink);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-header {
		position: absolute;
		inset: 0 0 auto;
		z-index: 5;
	}

	.top-bar {
		display: flex;
		justify-content: center;
		gap: 18px;
		padding: 10px clamp(16px, 4vw, 48px);
		background: rgba(8, 61, 114, 0.97);
		color: var(--white);
		font-size: 0.9rem;
		font-weight: 700;
		text-align: center;
	}

	.top-bar p {
		margin: 0;
	}

	.top-bar a {
		color: var(--orange);
		white-space: nowrap;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(1180px, calc(100% - 32px));
		margin: 18px auto 0;
		padding: 14px 18px;
		border: 1px solid rgba(255, 255, 255, 0.35);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 18px 50px rgba(8, 61, 114, 0.16);
		backdrop-filter: blur(12px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		min-width: 150px;
	}

	.brand-logo {
		width: min(190px, 38vw);
		height: 56px;
		border-radius: 6px;
		object-fit: contain;
		object-position: left center;
		background: var(--blue-soft);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: clamp(14px, 2.4vw, 28px);
		color: var(--blue-dark);
		font-size: 0.92rem;
		font-weight: 800;
	}

	.nav-call {
		padding: 10px 14px;
		border-radius: 6px;
		background: var(--orange);
		color: var(--white);
	}

	.hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 430px);
		align-items: end;
		gap: clamp(28px, 5vw, 72px);
		min-height: 88vh;
		padding: 185px clamp(18px, 6vw, 86px) 72px;
		background:
			linear-gradient(90deg, rgba(8, 61, 114, 0.92) 0%, rgba(8, 61, 114, 0.73) 46%, rgba(8, 61, 114, 0.24) 100%),
			url("https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=2200&q=82")
				center / cover;
		color: var(--white);
		overflow: hidden;
	}

	.hero::after {
		position: absolute;
		inset: auto 0 0;
		height: 160px;
		background: linear-gradient(180deg, rgba(255, 250, 241, 0), var(--cream));
		content: "";
		pointer-events: none;
	}

	.hero-content,
	.offer-form {
		position: relative;
		z-index: 1;
	}

	.hero-content {
		max-width: 760px;
		padding-bottom: 10px;
	}

	.eyebrow {
		display: inline-flex;
		margin: 0 0 18px;
		padding: 8px 12px;
		border-left: 4px solid var(--orange);
		background: rgba(255, 255, 255, 0.12);
		color: #ffe4ca;
		font-size: 0.82rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	h1 {
		max-width: 780px;
		margin: 0;
		font-size: clamp(2.75rem, 7vw, 5.9rem);
		line-height: 0.95;
		letter-spacing: 0;
	}

	.hero-copy {
		max-width: 650px;
		margin: 24px 0 0;
		color: rgba(255, 255, 255, 0.88);
		font-size: clamp(1.05rem, 2vw, 1.28rem);
		line-height: 1.6;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 30px;
	}

	.button {
		display: inline-flex;
		min-height: 52px;
		align-items: center;
		justify-content: center;
		border-radius: 6px;
		padding: 14px 20px;
		font-weight: 900;
	}

	.button.primary {
		background: var(--orange);
		color: #221104;
	}

	.button.secondary {
		border: 1px solid rgba(255, 255, 255, 0.55);
		background: rgba(255, 255, 255, 0.12);
		color: var(--white);
	}

	.trust-list {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin: 26px 0 0;
		padding: 0;
		list-style: none;
		color: rgba(255, 255, 255, 0.9);
		font-weight: 800;
	}

	.trust-list li {
		padding: 8px 12px;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.13);
	}

	.offer-form {
		display: grid;
		gap: 14px;
		padding: 24px;
		border-radius: 8px;
		background: var(--white);
		color: var(--ink);
		box-shadow: 0 28px 80px rgba(5, 38, 72, 0.28);
	}

	.form-heading p,
	.form-heading h2,
	.form-note {
		margin: 0;
	}

	.form-heading p {
		color: var(--orange);
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.form-heading h2 {
		margin-top: 4px;
		font-size: 1.55rem;
		line-height: 1.15;
	}

	label {
		display: grid;
		gap: 7px;
		color: var(--muted);
		font-size: 0.82rem;
		font-weight: 800;
	}

	input {
		width: 100%;
		min-height: 48px;
		border: 1px solid #d7ded8;
		border-radius: 6px;
		padding: 0 13px;
		color: var(--ink);
		font: inherit;
		background: #fbfcfb;
	}

	input:focus {
		border-color: var(--blue);
		box-shadow: 0 0 0 3px rgba(17, 100, 176, 0.14);
		outline: none;
	}

	.field-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
	}

	button {
		min-height: 52px;
		border: 0;
		border-radius: 6px;
		background: var(--blue);
		color: var(--white);
		cursor: pointer;
		font: inherit;
		font-weight: 900;
	}

	.form-note {
		color: var(--muted);
		font-size: 0.9rem;
		text-align: center;
	}

	.next-band {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: #dfe6df;
	}

	.next-band div {
		display: grid;
		gap: 6px;
		padding: 28px clamp(18px, 4vw, 56px);
		background: var(--cream);
	}

	.next-band strong {
		color: var(--orange);
		font-size: 0.78rem;
		text-transform: uppercase;
	}

	.next-band span {
		font-size: clamp(1.1rem, 2vw, 1.45rem);
		font-weight: 900;
	}

	.intro-section,
	.process-section,
	.situations-section,
	.offer-section {
		padding: clamp(58px, 8vw, 108px) clamp(18px, 6vw, 86px);
	}

	.section-kicker {
		color: var(--orange);
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.section-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.75fr);
		gap: clamp(28px, 6vw, 86px);
		align-items: start;
		max-width: 1160px;
		margin: 12px auto 0;
	}

	.intro-section h2,
	.situations-section h2,
	.offer-section h2 {
		margin: 0;
		font-size: clamp(2rem, 4.8vw, 4.6rem);
		line-height: 1;
		letter-spacing: 0;
	}

	.section-copy {
		display: grid;
		gap: 18px;
		color: var(--muted);
		font-size: 1.08rem;
		line-height: 1.72;
	}

	.section-copy p {
		margin: 0;
	}

	.process-section {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		padding-top: 0;
		background: linear-gradient(90deg, transparent 0, transparent clamp(18px, 6vw, 86px), #dfe6df clamp(18px, 6vw, 86px), #dfe6df calc(100% - clamp(18px, 6vw, 86px)), transparent calc(100% - clamp(18px, 6vw, 86px)));
	}

	.process-section article {
		display: grid;
		gap: 14px;
		min-height: 260px;
		padding: clamp(26px, 4vw, 46px);
		background: #ffffff;
	}

	.process-section span {
		color: var(--orange);
		font-size: 2.5rem;
		font-weight: 900;
	}

	.process-section h3,
	.situation-grid h3 {
		margin: 0;
		font-size: 1.35rem;
		line-height: 1.15;
	}

	.process-section p,
	.situation-grid p {
		margin: 0;
		color: var(--muted);
		line-height: 1.65;
	}

	.situations-section {
		background: var(--blue-soft);
	}

	.section-heading {
		display: grid;
		gap: 12px;
		max-width: 840px;
		margin: 0 auto clamp(28px, 5vw, 52px);
		text-align: center;
	}

	.situation-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		max-width: 1160px;
		margin: 0 auto;
	}

	.situation-grid article {
		display: grid;
		gap: 12px;
		padding: 26px;
		border: 1px solid #cfe2f5;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.78);
	}

	.situation-grid span {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border-radius: 50%;
		background: var(--blue);
		color: var(--white);
		font-weight: 900;
	}

	.offer-section {
		background:
			linear-gradient(90deg, rgba(8, 61, 114, 0.96), rgba(17, 100, 176, 0.82)),
			url("https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=2000&q=82")
				center / cover;
		color: var(--white);
	}

	.offer-panel {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 0.8fr);
		gap: clamp(28px, 5vw, 76px);
		align-items: center;
		max-width: 1160px;
		margin: 0 auto;
	}

	.offer-panel ul {
		display: grid;
		gap: 18px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.offer-panel li {
		display: grid;
		gap: 5px;
		padding-left: 18px;
		border-left: 4px solid var(--orange);
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.55;
	}

	.offer-panel strong {
		color: var(--white);
	}

	.offer-panel .button {
		justify-self: start;
	}

	@media (max-width: 920px) {
		.nav {
			align-items: flex-start;
		}

		.nav-links {
			flex-wrap: wrap;
			justify-content: flex-end;
		}

		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-top: 190px;
		}

		.offer-form {
			max-width: 580px;
		}

		.section-grid,
		.process-section,
		.situation-grid,
		.offer-panel {
			grid-template-columns: 1fr;
		}

		.process-section {
			background: #dfe6df;
			gap: 1px;
			padding-top: clamp(34px, 6vw, 58px);
		}
	}

	@media (max-width: 680px) {
		.top-bar {
			display: grid;
			gap: 5px;
			padding-block: 8px;
		}

		.nav {
			margin-top: 10px;
		}

		.nav-links a:not(.nav-call) {
			display: none;
		}

		.hero {
			padding: 166px 16px 44px;
			background:
				linear-gradient(180deg, rgba(8, 61, 114, 0.94) 0%, rgba(8, 61, 114, 0.76) 60%, rgba(8, 61, 114, 0.38) 100%),
